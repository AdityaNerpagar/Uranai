# Uranai — environment variables
# Copy to .env and fill in. For production, set these in the Vercel dashboard
# (Project → Settings → Environment Variables) or with `vercel env add`.

# --- Access control ---
# Admin password: unlimited readings + the Oracle Keys panel
ADMIN_PASSWORD=change-me
# Signs session tokens. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me

# --- AI provider ---
# One of: gemini | claude | groq
AI_PROVIDER=gemini
# Only the key for the chosen provider is required
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
# Optional model overrides
GEMINI_MODEL=gemini-3.1-flash-lite
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Key store (Upstash Redis, holds the one-time oracle keys) ---
# Provisioned automatically when you connect Upstash for Redis from the
# Vercel Marketplace; for local dev, run `vercel env pull` after linking,
# or copy the REST URL/token from the Upstash console.
# The UPSTASH_REDIS_REST_* naming works too.
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_TOKEN=
KV_REST_API_URL=
KV_URL=
REDIS_URL=